@startuml sequence_diagram

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam roundcorner 10
skinparam maxMessageSize 200

skinparam sequence {
    ArrowColor #333333
    LifeLineBorderColor #888888
    ParticipantBorderColor #444444
    ParticipantBackgroundColor white
    ParticipantFontStyle bold
    BoxBorderColor #aaaaaa
    BoxBackgroundColor #fafafa
    DividerBorderColor #888888
    DividerBackgroundColor #f0f0f0
}

participant "main.cpp" as Main
participant ":PipeIPCFactory" as Factory
participant ":IPCWriter\n(Pipe Server)" as PipeW
participant ":IPCReader\n(Pipe Client)" as PipeR
participant ":Producer" as P
participant ":EventSerializer" as Ser
participant ":Consumer" as C

== Startup ==

note over Main
  --transport pipe
  --producer / --consumer
end note

Main -> Factory : new PipeIPCFactory()
Main -> P       : runProducer(name, factory)
Main -> C       : runConsumer(name, factory)

P    -> Factory : createWriter(pipeName)
Factory -> PipeW : new IPCWriter(pipeName)
Factory --> P   : IIPCWriter

P    -> PipeW   : createPipe()\n[CreateNamedPipeA / mkfifo]
P    -> PipeW   : ConnectNamedPipe()\nblocking — wait for client

C    -> Factory : createReader(pipeName)
Factory -> PipeR : new IPCReader(pipeName)
Factory --> C   : IIPCReader

C    -> PipeR   : connect()\n[CreateFileA / open] retry loop
PipeR --> C     : connected
PipeW --> P     : consumer connected

== Event Loop ==

loop every ~500 ms

    P -> P     : generateEvent()\n{ component, severity, message }
    P -> Ser   : serialize(event) → JSON
    Ser --> P  : "{timestamp, component,\n severity, message}"
    P -> PipeW : write(json)
    PipeW -> PipeR : [Named Pipe / FIFO]

    C -> PipeR : read(message, 100 ms)
    PipeR --> C : json string
    C -> Ser   : deserialize(json) → Event
    Ser --> C  : Event

    alt severity < WARNING
        C -> C : discard (INFO filtered)
    else severity >= WARNING
        C -> C : stats_.warning/error_count++\ncomponent_severity_count update
        C -> C : print "[timestampToString(evt)]\n[Consumer] component [SEV] message"
    end

end

== Statistics (every 5 s) ==

C -> C : printStatistics()\nWARNINGs / ERRORs per component

== Shutdown: Consumer disconnects ==

C ->x PipeR : close pipe handle

PipeW -> P  : WriteFile → ERROR_BROKEN_PIPE\n(Windows) / EPIPE (Linux)
P -> PipeW  : reconnect()\nDisconnectNamedPipe + ConnectNamedPipe
note right of P : "Waiting for new consumer..."

...new consumer can connect again...

== Shutdown: Producer exits ==

P ->x PipeW : close / destroy pipe

PipeR -> C  : read() → EOF / BROKEN_PIPE\nthrow PipeDisconnectedException
C -> C      : catch PipeDisconnectedException\n"Producer has disconnected. Shutting down."

@enduml
